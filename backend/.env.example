# Database
DATABASE_URL=postgresql+asyncpg://bobcfc:bobcfc_secret@localhost:5432/bobcfc

# Redis
REDIS_URL=redis://localhost:6379/0

# RocketMQ
ROCKETMQ_NAMESRV=localhost:9876
ROCKETMQ_GROUP=backend-group

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=artifacts
MINIO_SECURE=false

# Auth (JWT, for session cookies)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# OIDC Authentication
# Set to "entra" or "adfs" to enable OIDC. Leave empty for demo mode.
OIDC_PROVIDER=

# Microsoft Entra ID (Azure AD)
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=common
ENTRA_AUTHORITY=https://login.microsoftonline.com
ENTRA_ROLE_MAPPINGS={"Global Administrator":"admin","User":"user"}

# ADFS (Active Directory Federation Services)
ADFS_CLIENT_ID=
ADFS_CLIENT_SECRET=
ADFS_ISSUER=
ADFS_AUTHORIZATION_URL=
ADFS_TOKEN_URL=
ADFS_USERINFO_URL=
ADFS_ROLE_MAPPINGS={"CN=Admins,OU=Groups,DC=company,DC=com":"admin"}

# Session
SESSION_MAX_AGE=28800

# Gemini / Google AI
GEMINI_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
